{
  "buildCommand": "npm install --prefix client && npm run build --prefix client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/home",
      "destination": "/api/home"
    },
    {
      "source": "/api/articles",
      "destination": "/api/articles"
    },
    {
      "source": "/api/articles/:id",
      "destination": "/api/articles?id=:id"
    },
    {
      "source": "/api/category/:slug",
      "destination": "/api/category?slug=:slug"
    },
    {
      "source": "/api/author/:slug",
      "destination": "/api/author?slug=:slug"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
